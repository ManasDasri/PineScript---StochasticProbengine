//@version=6
strategy("Prob", overlay=true, initial_capital=1000000, pyramiding=0, commission_type=strategy.commission.percent, commission_value=0.01, slippage=1, calc_on_every_tick=true, max_lines_count=500, max_labels_count=500, max_boxes_count=50)

// --- MEMORY ALLOCATION ---
max_bars_back(close, 2000)
max_bars_back(open,  2000)
max_bars_back(high,  2000)
max_bars_back(low,   2000)

// --- INPUTS ---
lookback              = input.int(1000, "Scan Depth", minval=50, maxval=1900, group="Core Engine")
k_matches             = input.int(10, "KNN Paths", minval=1, maxval=20, group="Core Engine")
prediction_window     = 20
strategy_scan_depth   = input.int(300, "Strategy Backtest Depth", minval=50, maxval=1000, group="Core Engine")

confidence_threshold  = input.float(65.0, "Entry Confidence (%)", minval=50.0, maxval=99.0, group="Filters")
min_required_matches  = input.int(8, "Min Valid Matches", minval=1, maxval=20, group="Filters")
poisson_gate_pct      = input.float(50.0, "Max Jump Risk to Enter (%)", minval=1.0, maxval=99.0, group="Filters")

max_position_pct      = input.float(10.0, "Max Position (% Bankroll)", minval=0.1, maxval=100.0, group="Risk Management")
max_bound_pct         = input.float(1.5, "Max Bound Width (% Price)", minval=0.1, maxval=20.0, group="Risk Management")
atr_stop_mult         = input.float(2.5, "ATR Stop Multiplier", minval=0.1, maxval=10.0, group="Risk Management")
reward_risk_ratio     = input.float(1.5, "Reward/Risk Ratio", minval=0.1, maxval=10.0, group="Risk Management")
max_bars_in_trade     = input.int(20, "Max Bars In Trade", minval=1, maxval=500, group="Risk Management")

strategy_enabled      = input.bool(true, "Enable Strategy Orders", group="Execution")
trade_direction       = input.string("Both", "Trade Direction", options=["Both", "Long only", "Short only"], group="Execution")

// --- AESTHETICS & ARRAYS ---
color neon_bull   = color.new(#089981, 40)
color neon_bear   = color.new(#F23645, 40)
color col_warn    = color.new(#FF9800, 0)

var line[]  drawn_lines   = array.new_line()
var label[] signal_labels = array.new_label()
var int     last_signal_label_bar = na
var label   replay_lbl    = na

var float   entry_atr     = na
var float   entry_stop_mult = na
var float   pending_entry_atr = na
var float   pending_entry_stop_mult = na

// --- BASE SERIES ---
float atr            = ta.atr(14)
float atr_ma         = ta.sma(atr, lookback)
float log_ret        = math.log(close / nz(close[1], close))
float hist_vol       = ta.stdev(log_ret, lookback)
float mean_log_ret   = ta.sma(log_ret, lookback)
float jump_threshold = hist_vol * 2.5
bool  is_jump        = math.abs(log_ret) > jump_threshold
float total_jumps    = math.sum(is_jump ? 1 : 0, lookback)
float lambda         = (total_jumps / lookback) * prediction_window
float poisson_prob_jump_series = (1.0 - math.exp(-lambda)) * 100.0

max_bars_back(atr, 2000)
max_bars_back(atr_ma, 2000)

// --- GLOBAL VARIABLES ---
var float prob_stay_high       = 50.0
var float limiting_prob_vol    = 50.0
var float poisson_prob_jump    = 0.0
var float adj_prob_bull        = 50.0
var float adj_prob_bear        = 50.0
var float optimal_size         = 0.0
var bool  is_bull_entry        = false
var bool  is_bear_entry        = false
var bool  poisson_suppressed   = false
var float atr_stop_distance    = 0.0

bool long_trade_signal  = false
bool short_trade_signal = false

// --- CORE ENGINE (PURE 1D PRICE ACTION & PERFECT ANCHOR) ---
if bar_index > lookback + prediction_window + 10

    int   scan_depth      = math.min(lookback, strategy_scan_depth)
    int   start_idx       = bar_index 
    float anchor_close    = close
    float anchor_atr      = atr
    int   anchor_state    = atr > atr_ma ? 1 : 0   

    // Clean up previous visual lines only on the live bar to save memory
    if barstate.islast and array.size(drawn_lines) > 0
        for i = 0 to array.size(drawn_lines) - 1
            line.delete(array.get(drawn_lines, i))
        array.clear(drawn_lines)

    // Markov Chain Scan
    int s00 = 0, int s01 = 0, int s10 = 0, int s11 = 0
    for i = 1 to scan_depth
        int s_curr = atr[i] > atr_ma[i] ? 1 : 0
        int s_prev = atr[i + 1] > atr_ma[i + 1] ? 1 : 0
        if s_prev == 0 and s_curr == 0
            s00 += 1
        else if s_prev == 0 and s_curr == 1
            s01 += 1
        else if s_prev == 1 and s_curr == 0
            s10 += 1
        else if s_prev == 1 and s_curr == 1
            s11 += 1

    float p0_total = math.max(1, s00 + s01)
    float p1_total = math.max(1, s10 + s11)
    float p01 = s01 / p0_total   
    float p10 = s10 / p1_total   
    float p00 = s00 / p0_total   
    float p11 = s11 / p1_total   

    prob_stay_high    := p11 * 100.0
    limiting_prob_vol := (p01 / math.max(p01 + p10, 0.0001)) * 100.0

    // Poisson Risk (Eq. 6)
    poisson_prob_jump := poisson_prob_jump_series
    poisson_suppressed := poisson_prob_jump >= poisson_gate_pct

    // KNN Engine Scan (Pure Log-Return Euclidean Distance per Eq. 1 & 2)
    float current_return = math.log(close / nz(close[prediction_window], close))
    float[] distances    = array.new_float()
    int[]   valid_indices = array.new_int()

    int min_match_idx = prediction_window + 1
    int max_scan      = math.min(scan_depth, bar_index - prediction_window)

    if max_scan >= min_match_idx
        for i = min_match_idx to max_scan
            float hist_return = math.log(close[i] / nz(close[i + prediction_window], close[i]))
            array.push(distances, math.abs(current_return - hist_return))
            array.push(valid_indices, i)

    int[] sorted_positions = array.sort_indices(distances)
    int bullish_outcomes   = 0
    int actual_matches     = math.min(k_matches, array.size(sorted_positions))
    int effective_min_matches = math.min(min_required_matches, k_matches)
    bool enough_knn_sample = actual_matches >= effective_min_matches

    if actual_matches > 0
        if barstate.islast
            label.delete(replay_lbl)
            replay_lbl := label.new(start_idx, high * 1.001, "⚠ Historical Paths (1D)", color=color.new(color.black, 40), textcolor=col_warn, style=label.style_label_down, size=size.small)

        for k = 0 to actual_matches - 1
            int match_idx = array.get(valid_indices, array.get(sorted_positions, k))
            
            // Log-return outcome to maintain mathematical consistency
            float outcome_return = math.log(close[match_idx - prediction_window] / nz(close[match_idx], close[match_idx]))
            
            if outcome_return > 0
                bullish_outcomes += 1

            if barstate.islast
                float sim_price = anchor_close
                int current_idx = start_idx 
                
                for s = 1 to prediction_window
                    float step_return = math.log(close[match_idx - s] / nz(close[match_idx - s + 1], 1.0))
                    float next_sim_price = sim_price * math.exp(step_return)
                    int next_idx = current_idx + 1

                    line p_line = line.new(current_idx, sim_price, next_idx, next_sim_price, color=outcome_return > 0 ? neon_bull : neon_bear, width=1)
                    array.push(drawn_lines, p_line)

                    sim_price := next_sim_price
                    current_idx := next_idx

    // Wilson Score Confidence Interval (Eq. 5)
    float knn_conf_low = 0.0
    float knn_conf_high = 100.0
    if actual_matches > 0
        float z = 1.96, float n = actual_matches, float phat = bullish_outcomes / n
        float denom = 1.0 + (z * z / n), float center = phat + (z * z / (2.0 * n))
        float margin = z * math.sqrt((phat * (1.0 - phat) / n) + (z * z / (4.0 * n * n)))
        knn_conf_low  := math.max(0.0, ((center - margin) / denom) * 100.0)
        knn_conf_high := math.min(100.0, ((center + margin) / denom) * 100.0)

    // Chebyshev Risk Bounds (Eq. 7)
    float expected_price = anchor_close * math.exp(mean_log_ret * prediction_window)
    float raw_dev        = nz(expected_price * (hist_vol * math.sqrt(prediction_window) * 3), 0.0)
    float bounds_dev     = math.min(raw_dev, anchor_close * (max_bound_pct / 100.0))
    float upper_bound    = math.min(expected_price + bounds_dev, anchor_close * (1.0 + max_bound_pct / 100.0))
    float lower_bound    = math.max(expected_price - bounds_dev, anchor_close * (1.0 - max_bound_pct / 100.0))

    if barstate.islast
        line u_line = line.new(start_idx, anchor_close, start_idx + prediction_window, upper_bound, color=color.new(color.yellow, 20), width=2, style=line.style_dashed)
        line d_line = line.new(start_idx, anchor_close, start_idx + prediction_window, lower_bound, color=color.new(color.yellow, 20), width=2, style=line.style_dashed)
        array.push(drawn_lines, u_line)
        array.push(drawn_lines, d_line)

    // Adjusted Probability & Kelly (Applying Markov Persistence to the Wilson Bound per Section 6.6)
    float state_persistence = anchor_state == 1 ? p11 : p00
    
    // Bull probability uses the Wilson Lower Bound
    adj_prob_bull := (knn_conf_low * state_persistence) + (50.0 * (1.0 - state_persistence))
    adj_prob_bull := math.min(math.max(adj_prob_bull, 0.0), 100.0)
    
    // Bear probability uses the inverse of the Wilson Upper Bound
    float wilson_bear_bound = 100.0 - knn_conf_high
    adj_prob_bear := (wilson_bear_bound * state_persistence) + (50.0 * (1.0 - state_persistence))

    // Strict 2.5 ATR stop logic per the manuscript
    atr_stop_distance := anchor_atr * atr_stop_mult
    float actual_rr_ratio = reward_risk_ratio 

    // Fractional Kelly Criterion (Eq. 8)
    float kelly_fraction = 0.5
    float long_kelly     = (adj_prob_bull / 100.0) - ((1.0 - (adj_prob_bull / 100.0)) / actual_rr_ratio)
    float short_kelly    = (adj_prob_bear / 100.0) - ((1.0 - (adj_prob_bear / 100.0)) / actual_rr_ratio)

    if adj_prob_bull > adj_prob_bear
        optimal_size := math.min(max_position_pct, math.max(0.0, long_kelly * kelly_fraction * 100.0))
    else
        optimal_size := math.min(max_position_pct, math.max(0.0, short_kelly * kelly_fraction * 100.0))

    // Entry Signals
    bool raw_bull = enough_knn_sample and adj_prob_bull >= confidence_threshold and optimal_size > 0.0 and not poisson_suppressed
    bool raw_bear = enough_knn_sample and adj_prob_bear >= confidence_threshold and optimal_size > 0.0 and not poisson_suppressed

    is_bull_entry := raw_bull and (trade_direction == "Both" or trade_direction == "Long only")
    is_bear_entry := raw_bear and (trade_direction == "Both" or trade_direction == "Short only")

    long_trade_signal  := is_bull_entry
    short_trade_signal := is_bear_entry

    if last_signal_label_bar != bar_index
        if is_bull_entry
            label b_lbl = label.new(bar_index, low, "LONG\n" + str.tostring(adj_prob_bull, "#.##") + "%", color=color.new(color.black, 40), textcolor=color.new(#089981, 0), style=label.style_label_up, yloc=yloc.belowbar)
            array.push(signal_labels, b_lbl)
            last_signal_label_bar := bar_index
        else if is_bear_entry
            label s_lbl = label.new(bar_index, high, "SHORT\n" + str.tostring(adj_prob_bear, "#.##") + "%", color=color.new(color.black, 40), textcolor=color.new(#F23645, 0), style=label.style_label_down, yloc=yloc.abovebar)
            array.push(signal_labels, s_lbl)
            last_signal_label_bar := bar_index

        if array.size(signal_labels) > 100
            label.delete(array.shift(signal_labels))


// --- STRATEGY EXECUTION ---
if strategy_enabled
    float kelly_pct = math.max(0.01, optimal_size)
    float qty_units = close > 0 ? (strategy.equity * kelly_pct / 100.0) / close : 0.0
    qty_units := math.max(0.000001, qty_units)

    if long_trade_signal and strategy.position_size == 0
        pending_entry_atr := atr
        pending_entry_stop_mult := atr_stop_mult
        strategy.entry("Long", strategy.long, qty=qty_units, comment="KNN-Bull")

    if short_trade_signal and strategy.position_size == 0
        pending_entry_atr := atr
        pending_entry_stop_mult := atr_stop_mult
        strategy.entry("Short", strategy.short, qty=qty_units, comment="KNN-Bear")

// Safe, clean state transition checks
if ta.change(strategy.position_size) != 0 and strategy.position_size != 0
    entry_atr := nz(pending_entry_atr, atr)
    entry_stop_mult := nz(pending_entry_stop_mult, atr_stop_mult) 

if strategy.position_size > 0 and not na(entry_atr)
    float entry_px = strategy.opentrades.entry_price(0)
    float sl_long  = entry_px - (entry_atr * entry_stop_mult)
    float tp_long  = entry_px + (entry_atr * entry_stop_mult * reward_risk_ratio)

    strategy.exit("Long-Exit", from_entry="Long", stop=sl_long, limit=tp_long)

    if (bar_index - strategy.opentrades.entry_bar_index(0)) >= max_bars_in_trade
        strategy.close("Long", comment="MaxBars")
    if short_trade_signal
        strategy.close("Long", comment="Reverse")

if strategy.position_size < 0 and not na(entry_atr)
    float entry_px = strategy.opentrades.entry_price(0)
    float sl_short = entry_px + (entry_atr * entry_stop_mult)
    float tp_short = entry_px - (entry_atr * entry_stop_mult * reward_risk_ratio)

    strategy.exit("Short-Exit", from_entry="Short", stop=sl_short, limit=tp_short)

    if (bar_index - strategy.opentrades.entry_bar_index(0)) >= max_bars_in_trade
        strategy.close("Short", comment="MaxBars")
    if long_trade_signal
        strategy.close("Short", comment="Reverse")

if strategy.position_size == 0
    entry_atr := na
    entry_stop_mult := na
    pending_entry_atr := na
    pending_entry_stop_mult := na


// --- DASHBOARD (PRO HUD MONOSPACE - GLOBAL SCOPE) ---
var color hud_bg   = color.new(color.black, 85)
var color txt_mute = color.new(color.white, 50)
var color txt_norm = color.white
var color val_up   = color.new(#089981, 0) 
var color val_dn   = color.new(#F23645, 0) 
var color val_warn = color.new(#FF9800, 0) 

// Anchored Top Right to avoid occlusion by the Strategy Tester panel
var table dash = table.new(position.top_right, 2, 11, border_width=0, frame_color=na, frame_width=0)

if barstate.islast
    table.cell(dash, 0, 0, "1D-KNN STOCHASTIC ENGINE", text_color=txt_norm, text_size=size.normal, text_halign=text.align_left, bgcolor=color.new(color.black, 100), text_font_family=font.family_monospace)
    table.cell(dash, 1, 0, "LIVE", text_color=val_up, text_size=size.normal, text_halign=text.align_right, bgcolor=color.new(color.black, 100), text_font_family=font.family_monospace)
    
    table.cell(dash, 0, 1, "Model Bias", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string bias_str = is_bull_entry ? "LONG" : is_bear_entry ? "SHORT" : "FLAT"
    color  bias_col = is_bull_entry ? val_up : is_bear_entry ? val_dn : txt_mute
    table.cell(dash, 1, 1, bias_str, text_color=bias_col, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 2, "Adj. Probability", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string prob_str = adj_prob_bull > 50 ? str.tostring(adj_prob_bull, "#.##") + "% Bull" : str.tostring(adj_prob_bear, "#.##") + "% Bear"
    color  prob_col = adj_prob_bull > 50 ? val_up : val_dn
    table.cell(dash, 1, 2, prob_str, text_color=prob_col, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 3, "Poisson Tail Risk", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string p_gate_str = str.tostring(poisson_prob_jump, "#.##") + "%" + (poisson_suppressed ? " [GATED]" : "")
    color  p_gate_col = poisson_suppressed ? val_dn : txt_norm
    table.cell(dash, 1, 3, p_gate_str, text_color=p_gate_col, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 4, "Kelly Allocation", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    table.cell(dash, 1, 4, str.tostring(optimal_size, "#.##") + "%", text_color=optimal_size > 0 ? txt_norm : txt_mute, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 5, "", bgcolor=color.new(color.black, 100))
    table.cell(dash, 1, 5, "", bgcolor=color.new(color.black, 100))

    table.cell(dash, 0, 6, "Strategy Position", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string pos_str = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    color  pos_col = strategy.position_size > 0 ? val_up : strategy.position_size < 0 ? val_dn : txt_mute
    table.cell(dash, 1, 6, pos_str, text_color=pos_col, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 7, "Net PnL", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string pnl_str = str.tostring((strategy.netprofit / strategy.initial_capital) * 100.0, "#.##") + "%"
    color  pnl_col = strategy.netprofit >= 0 ? val_up : val_dn
    table.cell(dash, 1, 7, pnl_str, text_color=pnl_col, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 8, "Win Rate", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    string wr_str = strategy.closedtrades > 0 ? str.tostring((strategy.wintrades / strategy.closedtrades) * 100.0, "#.##") + "%" : "0.00%"
    table.cell(dash, 1, 8, wr_str, text_color=txt_norm, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 9, "Max Drawdown", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    table.cell(dash, 1, 9, str.tostring(strategy.max_drawdown, "#.##"), text_color=val_dn, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)

    table.cell(dash, 0, 10, "Execution Engine", text_color=txt_mute, text_size=size.normal, text_halign=text.align_left, bgcolor=hud_bg, text_font_family=font.family_monospace)
    table.cell(dash, 1, 10, strategy_enabled ? "ENABLED" : "HALTED", text_color=strategy_enabled ? txt_norm : val_warn, text_size=size.normal, text_halign=text.align_right, bgcolor=hud_bg, text_font_family=font.family_monospace)
